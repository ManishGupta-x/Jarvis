# Copy this file to `.env` and fill in your real values.
# The `.env` file is gitignored and must NEVER be committed.

# Discord bot token (Discord Developer Portal > your app > Bot > Reset Token)
DISCORD_TOKEN=your-discord-bot-token

# MongoDB connection string (mongodb+srv://user:pass@cluster/db)
MONGODB_URI=your-mongodb-connection-string

# OpenAI API key (https://platform.openai.com/api-keys) - used by the gpt command
OPENAI_API_KEY=your-openai-api-key

# YouTube account cookie (optional)
YOUTUBE_COOKIE=your-youtube-cookie
